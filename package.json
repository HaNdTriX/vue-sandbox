{
  "name": "vue-sandbox",
  "type": "module",
  "version": "0.0.1",
  "description": "A Vue component for securely rendering untrusted HTML, CSS, and JavaScript inside an isolated iframe.",
  "author": "Henrik Wenz <handtrix@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/handtrix/library#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/handtrix/library.git"
  },
  "bugs": {
    "url": "https://github.com/handtrix/library/issues"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "release": "bumpp && pnpm publish",
    "prepublishOnly": "pnpm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@tsdown/css": "^0.21.1",
    "@types/node": "^25.3.5",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/browser-playwright": "^4.0.18",
    "bumpp": "^10.4.1",
    "playwright": "^1.58.2",
    "tsdown": "^0.21.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18",
    "vitest-browser-vue": "^2.0.2",
    "vue": "^3.5.29",
    "vue-codemirror": "^6.1.1",
    "vue-tsc": "^3.2.5"
  }
}
